# AI Discovery Canvas backend — environment variables.
#
# Copy to `.env` (same directory as main.py) and fill in what you need.
# Only vars actually read by the copied config modules are listed here —
# see app/core/config.py, app/auth/config.py, app/services/rag/config.py.
#
# `.env` is auto-loaded by app/core/config.py (_maybe_load_dotenv) if
# present — no extra tooling required.

# ── Server ────────────────────────────────────────────────────────────
APP_ENV=development
HOST=0.0.0.0
# 5101, not frd-generator's 5004, so both backends can run side-by-side.
PORT=5101
DEBUG=false

# Comma-separated. Defaults to the Next.js dev server on :3000 if unset.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Auth (app/auth/config.py) ────────────────────────────────────────
# 'mock' (default, no external IdP needed) or 'azure' (Microsoft Entra ID).
AUTH_MODE=mock
AUTH_JWT_SECRET=
AUTH_SESSION_TTL_SECONDS=28800
AUTH_DEFAULT_ROLE=user

# Needed for the "Sign in with Microsoft" button (works regardless of
# AUTH_MODE — see app/auth/routes.py). Same values as TEAMS_TENANT_ID/
# TEAMS_CLIENT_ID below — one app registration, reused for both. Public-
# client SPA app (PKCE) — genuinely no client secret anywhere in this flow.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Callback target for the (unused-by-default) server-side auth-code flow;
# the SPA/MSAL path doesn't need this, but set it to this project's own
# backend port if you ever exercise it (frd-generator's default was :5004,
# this project's backend is :5101).
AZURE_REDIRECT_URI=http://localhost:5101/auth/callback/azure
AZURE_AUTHORITY=
AZURE_SCOPES=openid profile email User.Read
AZURE_ALLOWED_TENANTS=
AZURE_VALIDATE_TOKENS=1

# ── Neo4j (app/core/config.py, app/database/neo4j_client.py) ────────
# This project's docker-compose.yml maps host ports 7475 (HTTP) / 7688
# (Bolt) to the container's standard 7474/7687 — chosen so it can run
# alongside frd-generator's own Neo4j stack. NEO4J_URI below targets the
# HOST-side Bolt port when running the backend on the host (not in
# docker-compose) against `docker compose up neo4j`.
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=canvas-dev
NEO4J_DATABASE=neo4j

# ── Secret resolution (app/services/secret_manager.py) ──────────────
# Set to 1 for local dev (no Azure Key Vault / az login available) so
# every secret below is read from env instead.
DISABLE_KEY_VAULT=1
KEY_VAULT_URL=

# ── AWS Bedrock — LLM (app/services/llm_service.py) ──────────────────
# Paste your AWS credentials here — these are boto3's own standard env-var
# names, so no extra plumbing is needed, just fill them in.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed if you're using temporary/STS credentials (leave blank for
# a long-lived IAM user access key).
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
# The Bedrock model id or inference-profile ARN to invoke — pick whichever
# model you've enabled access to in the Bedrock console, e.g.
# anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=
# Optional cheaper/faster model for the tiny per-message classification
# calls (Copilot's intent router, deepresearch's request classifier) —
# e.g. a Haiku-class model id. Falls back to BEDROCK_MODEL_ID when blank.
BEDROCK_ROUTER_MODEL_ID=
BEDROCK_MAX_RPM=50
BEDROCK_MAX_TPM=100000
BEDROCK_MAX_CONTEXT=200000
BEDROCK_MAX_OUTPUT=4096
BEDROCK_TIMEOUT=300
BEDROCK_MAX_RETRIES=5

# ── AWS Bedrock — embeddings / RAG (app/services/rag/config.py) ──────
# Same AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN /
# AWS_REGION above are reused for embeddings — no separate credentials
# needed. Just pick an embedding model id you have Bedrock access to:
# amazon.titan-embed-text-v2:0 (default, 1024-dim) or
# amazon.titan-embed-text-v1 (1536-dim, fixed) or
# cohere.embed-english-v3 / cohere.embed-multilingual-v3 (1024-dim).
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIM=1024
BEDROCK_EMBED_MAX_TPM=100000
BEDROCK_EMBED_MAX_RPM=60
BEDROCK_EMBED_MAX_WORKERS=8
BEDROCK_EMBED_MAX_INPUT_TOKENS=8000
BEDROCK_EMBED_MAX_RETRIES=6

RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64
RAG_CHUNK_MIN_TOKENS=24
RAG_TOP_K=8
RAG_MIN_SCORE=0.18
RAG_DATA_DIR=

# ── Postgres (app/postgres/) — BA -> Projects -> Workshops database ──
# Local instance, peer auth (no password) under a dedicated database —
# NOT the sibling NaviCore project's database, and unrelated to Neo4j.
# Created via: createdb ai_discovery_canvas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_discovery_canvas
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable

# ── Object storage (app/services/object_store.py) ────────────────────
OBJECT_STORE_BACKEND=local
OBJECT_STORE_DIR=

# ── Source-connection OAuth (app/services/source_oauth.py) ──────────
# Only needed if you wire up the GitHub / Azure DevOps "Connect" buttons.
GITHUB_OAUTH_CLIENT_ID=
AZURE_DEVOPS_OAUTH_CLIENT_ID=
# Client secrets are resolved via secret_manager (Key Vault names
# oauth-client-github-secret / oauth-client-azure-devops-secret); with
# DISABLE_KEY_VAULT=1, set the env fallback directly:
GITHUB_OAUTH_CLIENT_SECRET=
AZURE_DEVOPS_OAUTH_CLIENT_SECRET=
CONNECTIONS_REDIRECT_BASE=

# ── Health probes (app/routes/health.py) ─────────────────────────────
HEALTH_REQUIRE_NEO4J=1

# ── Microsoft Teams via Graph API (app/services/graph_teams.py) ───────
# Reuses the SAME Entra ID app registration NaviCore uses for sign-in
# (tenant + client id — these are identifiers, not secrets). Device-code
# flow, so NO client secret is needed. Before live use, the Azure admin
# must enable "Allow public client flows" on the app registration and
# grant admin-consented delegated Graph permissions: OnlineMeetings.Read,
# OnlineMeetingTranscript.Read.All. Falls back to AZURE_TENANT_ID /
# AZURE_CLIENT_ID if these are unset.
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=

# OPTIONAL — last-resort organizer fallback for meetings you were only
# INVITED to (not organizer). Only needed if the id-construction fix in
# graph_teams.py's _resolve_meeting doesn't apply to a given join URL;
# most cases need nothing here. Requires the app registration's OWNER
# (or a tenant admin) to, in Azure Portal: (1) add a client secret and
# paste its VALUE here (or as Key Vault secret 'teams-client-secret');
# (2) add Microsoft Graph APPLICATION permissions OnlineMeetings.Read.All
# + OnlineMeetingTranscript.Read.All; (3) grant admin consent for those.
# See graph_teams.py's module docstring for the full detail. Leave blank
# to skip this fallback entirely — everything else keeps working.
TEAMS_CLIENT_SECRET=

# ── Granola (app/routes/integrations.py) — FLOW ONLY, not live ────────
# Needs a Granola Business-plan API key; deliberately left unset (no
# subscription today). The UI flow exists and reports "not connected".
GRANOLA_API_KEY=

# ── Deep web search — Tavily (app/services/web_search.py) ────────────
# Used by the /deepresearch agent's real web-search step. No existing
# access anywhere (confirmed — neither this project nor NaviCore's had a
# search API before this). Free tier available at https://tavily.com.
TAVILY_API_KEY=

# ── LLM backend selection (app/services/llm_service.py) ──────────────
# Platform default backend: 'azure_openai' or 'bedrock'. Each user can
# override it from the header avatar menu (persisted per account on
# users.llm_provider); this default serves anyone who hasn't picked,
# plus background jobs that run outside a request (doc indexing).
LLM_PROVIDER=azure_openai

# ── Azure OpenAI — LLM alternative (app/services/llm_azure.py) ───────
# Chat/completions only — embeddings/RAG stay on Bedrock Titan.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=
# Optional cheaper deployment for tiny router/classifier calls (the
# Azure counterpart of BEDROCK_ROUTER_MODEL_ID). Falls back to
# AZURE_OPENAI_DEPLOYMENT when unset.
AZURE_OPENAI_ROUTER_DEPLOYMENT=
AZURE_OPENAI_MAX_RPM=60
AZURE_OPENAI_MAX_TPM=100000
AZURE_OPENAI_MAX_CONTEXT=128000
AZURE_OPENAI_MAX_OUTPUT=4096
AZURE_OPENAI_TIMEOUT=300
AZURE_OPENAI_MAX_RETRIES=5

# ── Azure OpenAI embeddings — RAG alternative (app/services/rag/embedder_azure.py)
# Follows the SAME provider choice as chat (LLM_PROVIDER / the user's
# header-menu pick): 'azure_openai' uses this deployment, 'bedrock' uses
# BEDROCK_EMBEDDING_MODEL_ID above. Kept in a separate FAISS namespace
# from Bedrock's (different embedding models are incomparable vector
# spaces) — see rag/service.py's module docstring.
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_DEPLOYMENT=
AZURE_EMBEDDING_API_VERSION=2024-02-01
# Falls back to AZURE_OPENAI_API_KEY when unset (same Azure resource).
AZURE_EMBEDDING_API_KEY=
# text-embedding-3-large's native width is 3072; text-embedding-3-small
# is 1536. Lower values are sent as the request's `dimensions` param
# (Matryoshka truncation, supported down to 256).
AZURE_EMBEDDING_DIM=3072
AZURE_EMBED_MAX_RPM=120
AZURE_EMBED_MAX_TPM=350000
AZURE_EMBED_MAX_RETRIES=6
AZURE_EMBED_BATCH_SIZE=16
AZURE_EMBED_MAX_WORKERS=8
